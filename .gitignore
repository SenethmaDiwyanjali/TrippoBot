backups/

# Operating System Files
.DS_Store
Thumbs.db
desktop.ini

# IDEs and Editors
.vscode/
.idea/
*.swp
*.sublime-project

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Vercel Deployment
.vercel/